node_modules/
.wrangler/
.dev.vars

# Vite build output (generated by npm run build / wrangler deploy)
public/app/

# Local scratch: Playwright verification scripts + screenshots
web/verify-*.mjs
web/*.png

# Capacitor: native build output + web assets synced into the native projects
# (regenerated by `npm run cap:sync`). The ios/ and android/ projects keep
# their own .gitignore for Pods/build artifacts.
web/dist/
web/ios/App/App/public/
web/android/app/src/main/assets/public/
web/ios/App/build/

# Raw (unframed) device captures — local working files. Final framed App Store
# screenshots in store/iphone-6.9 and store/ipad-13 are committed.
store/raw/
